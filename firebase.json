{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "goldmonitor"
        }
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
